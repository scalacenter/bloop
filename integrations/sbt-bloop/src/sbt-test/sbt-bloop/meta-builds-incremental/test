# Loading exports the meta-build once.
> checkMetaPresent
> recordMetaMtime
# A reload with no build-definition change must skip the export (config untouched).
$ sleep 2000
> reload
> checkMetaPresent
> checkMetaUnchanged
# Touching a build-definition source must regenerate the export.
$ sleep 2000
$ touch project/plugins.sbt
> reload
> checkMetaPresent
> checkMetaRegenerated
# Deleting a build-definition source must also regenerate (guards against stale state).
> recordMetaMtime
$ sleep 2000
$ delete project/extra.sbt
> reload
> checkMetaPresent
> checkMetaRegenerated
# A non-source file under project/ is fingerprinted too, so changing it regenerates.
> recordMetaMtime
$ sleep 2000
$ touch project/versions.properties
> reload
> checkMetaPresent
> checkMetaRegenerated
